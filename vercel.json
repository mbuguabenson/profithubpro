{
    "builds": [
        { "src": "package.json", "use": "@vercel/static-build" },
        { "src": "api/**/*.ts", "use": "@vercel/node" }
    ],
    "outputDirectory": "dist",
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/$1.ts" },
        { "handle": "filesystem" },
        { "src": "/(.*)", "dest": "/index.html" }
    ]
}
